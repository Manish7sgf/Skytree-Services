# Backend API URL (set this when backend is deployed)
VITE_API_BASE_URL=https://your-backend-url.railway.app

# EmailJS (if used — get from emailjs.com dashboard)
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id  
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# ── Umang API (TN Police) ─────────────────────────────────
VITE_UMANG_X_API_KEY=your_umang_api_key_here

# ── ApiSetu (Birth/Death + TN eDistrict) ──────────────────
VITE_API_SETU_KEY=your_apisetu_key_here
VITE_API_SETU_CLIENT_ID=your_apisetu_client_id_here

